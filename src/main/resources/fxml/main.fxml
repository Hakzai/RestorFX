<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.akeir.restaurant.controller.MainController"
            prefHeight="600.0"
            prefWidth="900.0"
            styleClass="root-layout">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER_LEFT" styleClass="header-box">
            <padding>
                <Insets top="20.0" right="24.0" bottom="12.0" left="24.0" />
            </padding>
            <Label text="Restaurant Management" styleClass="title-label" />
            <Label fx:id="subtitleLabel" styleClass="subtitle-label" />
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="content-tabs">
            <tabs>
                <Tab text="Menu">
                    <content>
                        <HBox spacing="20.0" BorderPane.alignment="CENTER">
                            <padding>
                                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
                            </padding>

                            <VBox spacing="10.0" styleClass="panel-card">
                                <children>
                                    <Label text="Menu Items" styleClass="section-title" />
                                    <TableView fx:id="menuTable" prefHeight="420.0" prefWidth="560.0">
                                        <columns>
                                            <TableColumn fx:id="idColumn" prefWidth="60.0" text="ID" />
                                            <TableColumn fx:id="nameColumn" prefWidth="250.0" text="Name" />
                                            <TableColumn fx:id="priceColumn" prefWidth="120.0" text="Price" />
                                            <TableColumn fx:id="activeColumn" prefWidth="100.0" text="Active" />
                                        </columns>
                                    </TableView>
                                </children>
                                <HBox.hgrow>
                                    <Priority fx:constant="ALWAYS" />
                                </HBox.hgrow>
                            </VBox>

                            <VBox spacing="10.0" styleClass="panel-card" prefWidth="280.0">
                                <children>
                                    <Label text="Item Form" styleClass="section-title" />

                                    <Label text="Name" styleClass="field-label" />
                                    <TextField fx:id="nameField" promptText="e.g. Burger" />

                                    <Label text="Description" styleClass="field-label" />
                                    <TextArea fx:id="descriptionField" prefRowCount="3" promptText="Optional details" wrapText="true" />

                                    <Label text="Price" styleClass="field-label" />
                                    <TextField fx:id="priceField" promptText="e.g. 19.90" />

                                    <CheckBox fx:id="activeCheckBox" text="Active" selected="true" />

                                    <HBox spacing="8.0">
                                        <Button text="Add" styleClass="action-button" onAction="#onAddItem" />
                                        <Button text="Update" styleClass="action-button" onAction="#onUpdateItem" />
                                    </HBox>

                                    <HBox spacing="8.0">
                                        <Button text="Delete" styleClass="danger-button" onAction="#onDeleteItem" />
                                        <Button text="Clear" styleClass="secondary-button" onAction="#onClearForm" />
                                    </HBox>

                                    <Label fx:id="menuFeedbackLabel" styleClass="feedback-label" text="Select, add, edit, or delete menu items" wrapText="true" />
                                </children>
                            </VBox>
                        </HBox>
                    </content>
                </Tab>

                <Tab text="Customers">
                    <content>
                        <HBox spacing="20.0" BorderPane.alignment="CENTER">
                            <padding>
                                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
                            </padding>

                            <VBox spacing="10.0" styleClass="panel-card">
                                <children>
                                    <Label text="Customers" styleClass="section-title" />
                                    <HBox spacing="8.0">
                                        <TextField fx:id="customerSearchField" onKeyReleased="#onCustomerSearchChanged" promptText="Search by name, document, phone, or email" HBox.hgrow="ALWAYS" />
                                        <Button text="Clear" styleClass="secondary-button" onAction="#onClearCustomerSearch" />
                                    </HBox>
                                    <Label fx:id="customerFilterSummaryLabel" styleClass="support-label" text="Showing 0 of 0 customers" />
                                    <TableView fx:id="customerTable" prefHeight="420.0" prefWidth="560.0">
                                        <columns>
                                            <TableColumn fx:id="customerIdColumn" prefWidth="60.0" text="ID" />
                                            <TableColumn fx:id="customerNameColumn" prefWidth="170.0" text="Name" />
                                            <TableColumn fx:id="customerDocumentColumn" prefWidth="120.0" text="Document" />
                                            <TableColumn fx:id="customerPhoneColumn" prefWidth="120.0" text="Phone" />
                                            <TableColumn fx:id="customerEmailColumn" prefWidth="170.0" text="Email" />
                                        </columns>
                                    </TableView>
                                </children>
                                <HBox.hgrow>
                                    <Priority fx:constant="ALWAYS" />
                                </HBox.hgrow>
                            </VBox>

                            <VBox spacing="10.0" styleClass="panel-card" prefWidth="280.0">
                                <children>
                                    <Label text="Customer Form" styleClass="section-title" />

                                    <Label text="Name" styleClass="field-label" />
                                    <TextField fx:id="customerNameField" promptText="e.g. Maria Silva" />

                                    <Label text="Document" styleClass="field-label" />
                                    <TextField fx:id="customerDocumentField" promptText="e.g. 123.456.789-10" />

                                    <Label text="Phone" styleClass="field-label" />
                                    <TextField fx:id="customerPhoneField" promptText="e.g. +55 11 99999-9999" />

                                    <Label text="Email" styleClass="field-label" />
                                    <TextField fx:id="customerEmailField" promptText="e.g. customer@email.com" />

                                    <HBox spacing="8.0">
                                        <Button text="Add" styleClass="action-button" onAction="#onAddCustomer" />
                                        <Button text="Update" styleClass="action-button" onAction="#onUpdateCustomer" />
                                    </HBox>

                                    <HBox spacing="8.0">
                                        <Button text="Delete" styleClass="danger-button" onAction="#onDeleteCustomer" />
                                        <Button text="Clear" styleClass="secondary-button" onAction="#onClearCustomerForm" />
                                    </HBox>

                                    <Label fx:id="customerFeedbackLabel" styleClass="feedback-label" text="Select, add, edit, or delete customers" wrapText="true" />
                                </children>
                            </VBox>
                        </HBox>
                    </content>
                </Tab>

                <Tab text="NFe Mock">
                    <content>
                        <HBox spacing="20.0" BorderPane.alignment="CENTER">
                            <padding>
                                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
                            </padding>

                            <VBox spacing="10.0" styleClass="panel-card" prefWidth="340.0">
                                <children>
                                    <Label text="NFe Mock Form" styleClass="section-title" />

                                    <Label text="Customer Name" styleClass="field-label" />
                                    <TextField fx:id="nfeCustomerNameField" promptText="e.g. Maria Silva" />

                                    <Label text="Customer Document" styleClass="field-label" />
                                    <TextField fx:id="nfeCustomerDocumentField" promptText="e.g. 12345678910" />

                                    <Label text="Total Amount" styleClass="field-label" />
                                    <TextField fx:id="nfeTotalAmountField" promptText="e.g. 145.90" />

                                    <Label text="Additional Notes" styleClass="field-label" />
                                    <TextArea fx:id="nfeNotesField" prefRowCount="4" promptText="Optional fiscal notes" wrapText="true" />

                                    <HBox spacing="8.0">
                                        <Button text="Emit Mock NFe" styleClass="action-button" onAction="#onEmitNFeMock" />
                                        <Button text="Clear" styleClass="secondary-button" onAction="#onClearNFeForm" />
                                    </HBox>

                                    <Label fx:id="nfeFeedbackLabel" styleClass="feedback-label" text="Fill the form and emit a mocked NFe" wrapText="true" />
                                </children>
                            </VBox>

                            <VBox spacing="10.0" styleClass="panel-card">
                                <children>
                                    <Label text="Mock XML Output" styleClass="section-title" />
                                    <TextArea fx:id="nfeXmlOutputArea"
                                              editable="false"
                                              prefHeight="420.0"
                                              prefWidth="500.0"
                                              wrapText="true"
                                              styleClass="xml-output-area"
                                              promptText="XML output will appear here after mock emission" />
                                </children>
                                <HBox.hgrow>
                                    <Priority fx:constant="ALWAYS" />
                                </HBox.hgrow>
                            </VBox>
                        </HBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
