<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.akeir.restaurant.controller.MainController"
            prefHeight="600.0"
            prefWidth="900.0"
            styleClass="root-layout">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER_LEFT" styleClass="header-box">
            <padding>
                <Insets top="20.0" right="24.0" bottom="12.0" left="24.0" />
            </padding>
            <Label text="Restaurant Management" styleClass="title-label" />
            <Label fx:id="subtitleLabel" styleClass="subtitle-label" />
        </VBox>
    </top>
    <center>
        <HBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
            </padding>

            <VBox spacing="10.0" styleClass="panel-card">
                <children>
                    <Label text="Menu Items" styleClass="section-title" />
                    <TableView fx:id="menuTable" prefHeight="420.0" prefWidth="560.0">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="60.0" text="ID" />
                            <TableColumn fx:id="nameColumn" prefWidth="250.0" text="Name" />
                            <TableColumn fx:id="priceColumn" prefWidth="120.0" text="Price" />
                            <TableColumn fx:id="activeColumn" prefWidth="100.0" text="Active" />
                        </columns>
                    </TableView>
                </children>
                <HBox.hgrow>
                    <Priority fx:constant="ALWAYS" />
                </HBox.hgrow>
            </VBox>

            <VBox spacing="10.0" styleClass="panel-card" prefWidth="280.0">
                <children>
                    <Label text="Item Form" styleClass="section-title" />

                    <Label text="Name" styleClass="field-label" />
                    <TextField fx:id="nameField" promptText="e.g. Burger" />

                    <Label text="Description" styleClass="field-label" />
                    <TextArea fx:id="descriptionField" prefRowCount="3" promptText="Optional details" wrapText="true" />

                    <Label text="Price" styleClass="field-label" />
                    <TextField fx:id="priceField" promptText="e.g. 19.90" />

                    <CheckBox fx:id="activeCheckBox" text="Active" selected="true" />

                    <HBox spacing="8.0">
                        <Button text="Add" styleClass="action-button" onAction="#onAddItem" />
                        <Button text="Update" styleClass="action-button" onAction="#onUpdateItem" />
                    </HBox>

                    <HBox spacing="8.0">
                        <Button text="Delete" styleClass="danger-button" onAction="#onDeleteItem" />
                        <Button text="Clear" styleClass="secondary-button" onAction="#onClearForm" />
                    </HBox>

                    <Label fx:id="feedbackLabel" styleClass="feedback-label" text="Select, add, edit, or delete menu items" wrapText="true" />
                </children>
            </VBox>
        </HBox>
    </center>
</BorderPane>
